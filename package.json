{
  "name": "nexus-webfont-converter",
  "version": "1.0.1",
  "description": "Converter for desktop font files (TTF, OTF) to web font formats (WOFF, WOFF2)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "wfc": "./dist/cli/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "git clean -dfx && npm ci && npm run test && npm run build",
    "prepublishOnly": "npm run lint:fix && npm run test && npm run build",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "build": "rimraf dist && tsc --build --clean && tsc -p tsconfig.lib.json && node -e \"require('fs').chmodSync('dist/cli/cli.js',0o755)\"",
    "build:watch": "tsc --build --clean && tsc -p tsconfig.lib.json --watch",
    "convert": "gulp --silent --gulpfile dist/gulpfile.js",
    "compile-css": "gulp compileCss --silent --gulpfile dist/gulpfile.js",
    "recompile-html": "gulp recompileHtml --silent --gulpfile dist/gulpfile.js",
    "remove-unused": "gulp removeUnused --silent --gulpfile dist/gulpfile.js",
    "sync": "gulp sync --silent --gulpfile dist/gulpfile.js",
    "update-npm": "ncu -t minor --deep -u --rejectVersion \"/^\\d+\\.\\d+\\.\\d+$/\" --cooldown 14"
  },
  "dependencies": {
    "@types/cli-progress": "^3.11.6",
    "browserslist": "^4.28.1",
    "cli-progress": "^3.12.0",
    "del": "^8.0.1",
    "gulp": "^5.0.1",
    "gulp-lightningcss": "^1.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "picocolors": "^1.1.1",
    "sass": "^1.97.3",
    "tslib": "^2.8.1",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/gulp": "^4.0.18",
    "@types/gulp-rename": "^2.0.7",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25",
    "app-root-path": "^3.1.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.6.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">= 24.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vsjov/nexus-webfont-converter.git"
  },
  "homepage": "https://github.com/vsjov/nexus-webfont-converter#readme",
  "bugs": {
    "url": "https://github.com/vsjov/nexus-webfont-converter/issues"
  },
  "keywords": [
    "webfont",
    "woff",
    "woff2",
    "ttf",
    "otf",
    "font-converter",
    "cli"
  ],
  "license": "Apache-2.0",
  "author": "Vladimir Jovanović <vladimir@bitersen.com>"
}
