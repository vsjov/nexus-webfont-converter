{
  "name": "nexus-webfont-converter",
  "version": "1.0.0",
  "description": "Nexus Webfont Converter",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "author": "Vladimir Jovanović <vladimir@bitersen.com>",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "build": "rimraf dist && tsc --build --clean && tsc -p tsconfig.lib.json",
    "build:watch": "tsc --build --clean && tsc -p tsconfig.lib.json --watch",
    "convert": "gulp --gulpfile dist/gulpfile.js",
    "update-npm": "ncu -t minor --deep -u --rejectVersion \"/^\\d+\\.\\d+\\.\\d+$/\" --cooldown 14"
  },
  "dependencies": {
    "del": "^8.0.1",
    "fancy-log": "^2.0.0",
    "gulp": "^5.0.1",
    "gulp-lightningcss": "^1.0.0",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "picocolors": "^1.1.1",
    "sass": "^1.97.3",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/fancy-log": "^2.0.2",
    "@types/gulp": "^4.0.18",
    "@types/gulp-rename": "^2.0.7",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24",
    "app-root-path": "^3.1.0",
    "eslint-plugin-jsdoc": "^57.2.1",
    "eslint-plugin-vue": "9.33.0",
    "jiti": "^2.6.1",
    "jsdom": "^28.1.0",
    "npm-check-updates": "^19.6.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">= 20.10.0"
  }
}
