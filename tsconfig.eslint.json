{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/*.ts",
    "src/**/*.ts",
    "src/**/*.*.ts",
    "eslint.*.ts",
    "eslint.*.*.ts",
    "*.json",
    "**/*.json",
    "vite.config.ts",
    "vitest.config.ts",
  ],
  "exclude": [
    "node_modules",
  ]
}
