{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
    ]
  },
  "include": [
    "vite.config.ts",
    "src/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.d.ts",
    "package.json",
    "src/**/*.json"
  ]
}
